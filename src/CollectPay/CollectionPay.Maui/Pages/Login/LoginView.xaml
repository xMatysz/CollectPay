<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CollectionPay.Maui.Pages.Login"
             x:Class="CollectionPay.Maui.Pages.Login.LoginView"
             x:DataType="local:LoginViewModel">
    <VerticalStackLayout HorizontalOptions="Center"
                         VerticalOptions="Center">
        <Label Text="UserName"/>
        <Entry Text="{Binding Model.UserName, Mode=OneWayToSource}"/>

        <Label Text="Password"/>
        <Entry Text="{Binding Model.Password, Mode=OneWayToSource}"/>

        <Button Text="Login" Command="{Binding LoginCommand}"/>
    </VerticalStackLayout>
</ContentPage>