<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CollectionPay.Maui.Pages.Register"
             x:Class="CollectionPay.Maui.Pages.Register.RegisterView"
             x:DataType="local:RegisterViewModel">
    <VerticalStackLayout HorizontalOptions="Center"
                         VerticalOptions="Center">
        <Label Text="Email"/>
        <Entry Text="{Binding Model.Email, Mode=OneWayToSource}"/>

        <Label Text="Password"/>
        <Entry Text="{Binding Model.Password, Mode=OneWayToSource}"/>

        <Label Text="NickName"/>
        <Entry Text="{Binding Model.NickName, Mode=OneWayToSource}"/>

        <Button Text="Login" Command="{Binding SendRegisterRequestCommand}"/>
    </VerticalStackLayout>
</ContentPage>